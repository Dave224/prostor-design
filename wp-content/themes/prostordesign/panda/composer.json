{
  "name": "panda-wp/panda",
  "description": "",
  "authors": [
    {
      "name": "Jakub Jetleb",
      "email": "jakubjetleb@gmail.com"
    }
  ],
  "config": {
    "vendor-dir": "Vendor",
    "optimize-autoloader": true,
    "classmap-authoritative": true,
    "notify-on-install": false
  },
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "files": [
      "Init.php"
    ],
    "psr-4": {
      "Components\\": "Components",
      "Services\\": "Services",
      "Extensions\\": "Extensions",
      "Utils\\": "Utils",
      "Enums\\": "Enums",
      "Presenters\\": "Presenters",
      "Models\\": "Models",
      "Configs\\": "Configs",
      "Interfaces\\": "Interfaces",
      "Layouts\\": "Layouts",
      "Admin\\": "Admin",
      "Helpers\\": "Helpers"
    }
  },
  "require-dev": {
    "symfony/var-dumper": "^6.0",
    "tracy/tracy": "^2.10",
    "symfony/error-handler": "^6.0"
  }
}
